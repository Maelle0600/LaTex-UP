@article{PEREIRAInhibitionMitochondrialComplex2013,
  title     = {Inhibition of {{Mitochondrial Complex III Blocks Neuronal Differentiation}} and {{Maintains Embryonic Stem Cell Pluripotency}}},
  author    = {Pereira, Sandro L. and Gr{\~a}os, M{\'a}rio and Rodrigues, Ana Sofia and Anjo, Sandra I. and Carvalho, Rui A. and Oliveira, Paulo J. and Arenas, Ernest and {Ramalho-Santos}, Jo{\~a}o},
  year      = 2013,
  month     = dec,
  journal   = {PLOS ONE},
  volume    = {8},
  number    = {12},
  pages     = {e82095},
  publisher = {Public Library of Science},
  issn      = {1932-6203},
  doi       = {10.1371/journal.pone.0082095},
  urldate   = {2026-04-09},
  abstract  = {The mitochondrion is emerging as a key organelle in stem cell biology, acting as a regulator of stem cell pluripotency and differentiation. In this study we sought to understand the effect of mitochondrial complex III inhibition during neuronal differentiation of mouse embryonic stem cells. When exposed to antimycin A, a specific complex III inhibitor, embryonic stem cells failed to differentiate into dopaminergic neurons, maintaining high Oct4 levels even when subjected to a specific differentiation protocol. Mitochondrial inhibition affected distinct populations of cells present in culture, inducing cell loss in differentiated cells, but not inducing apoptosis in mouse embryonic stem cells. A reduction in overall proliferation rate was observed, corresponding to a slight arrest in S phase. Moreover, antimycin A treatment induced a consistent increase in HIF-1{$\alpha$} protein levels. The present work demonstrates that mitochondrial metabolism is critical for neuronal differentiation and emphasizes that modulation of mitochondrial functions through pharmacological approaches can be useful in the context of controlling stem cell maintenance/differentiation.},
  langid    = {english},
  keywords  = {Cell differentiation,Dopaminergics,Embryonic stem cells,Mitochondria,Neuronal differentiation,Pluripotency,Stem cell therapy,Stem cells}
}

@article{pilzAmplificationProgenitorsMammalian2013,
  title     = {Amplification of Progenitors in the Mammalian Telencephalon Includes a New Radial Glial Cell Type},
  author    = {Pilz, Gregor-Alexander and Shitamukai, Atsunori and Reillo, Isabel and Pacary, Emilie and Schwausch, Julia and Stahl, Ronny and Ninkovic, Jovica and Snippert, Hugo J. and Clevers, Hans and Godinho, Leanne and Guillemot, Francois and Borrell, Victor and Matsuzaki, Fumio and G{\"o}tz, Magdalena},
  year      = 2013,
  month     = jul,
  journal   = {Nature Communications},
  volume    = {4},
  number    = {1},
  pages     = {2125},
  publisher = {Nature Publishing Group},
  issn      = {2041-1723},
  doi       = {10.1038/ncomms3125},
  urldate   = {2026-04-21},
  abstract  = {The mechanisms governing the expansion of neuron number in specific brain regions are still poorly understood. Enlarged neuron numbers in different species are often anticipated by increased numbers of progenitors dividing in the subventricular zone. Here we present live imaging analysis of radial glial cells and their progeny in the ventral telencephalon, the region with the largest subventricular zone in the murine brain during neurogenesis. We observe lineage amplification by a new type of progenitor, including bipolar radial glial cells dividing at subapical positions and generating further proliferating progeny. The frequency of this new type of progenitor is increased not only in larger clones of the mouse lateral ganglionic eminence but also in cerebral cortices of gyrated species, and upon inducing gyrification in the murine cerebral cortex. This implies key roles of this new type of radial glia in ontogeny and phylogeny.},
  copyright = {2013 The Author(s)},
  langid    = {english},
  keywords  = {Glial development,Neurogenesis}
}

